# --- Core ---
NODE_NAME=node1
HTTP_PORT=8080

# --- Master behavior ---
# When TRUE, seeds welcome.md on boot and accepts inbound hellos.
MASTER=TRUE
# MANUAL = require admin approval; AUTO = approve on first hello.
NEIGHBORS=MANUAL

# --- Auth (required) ---
ADMIN_PASSWORD=changeme

# --- Storage paths (defaults shown) ---
DATA_DIR=/data
KEYS_DIR=/keys

# --- Networking ---
# Comma-separated host:port list used ONCE on boot to bootstrap first hellos.
SEED_PEERS=
# Comma-separated upstream master(s) this node reports discoveries to.
MASTER_PEERS=

# --- Sync behavior ---
# If TRUE, propagate file deletions to/from neighbors.
DELETE_LOCAL=FALSE
# Max file size in MB; chunk size stays 64 MB.
MAX_FILE_SIZE_MB=2048